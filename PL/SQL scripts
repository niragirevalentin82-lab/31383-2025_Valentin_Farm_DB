---------- farm operations (procedures, functions, cursor, exceptions)--------------
CREATE OR REPLACE PACKAGE farm_pkg AS

    -- Custom exception
    e_insufficient_qty EXCEPTION;

    PROCEDURE register_harvest (
        p_farm_id  IN harvest.farm_id%TYPE,
        p_crop_id  IN harvest.crop_id%TYPE,
        p_date     IN harvest.harvest_date%TYPE,
        p_qty      IN harvest.quantity%TYPE,
        p_grade    IN harvest.quality_grade%TYPE
    );

    PROCEDURE record_sale (
        p_harvest_id IN sale.harvest_id%TYPE,
        p_buyer_id   IN sale.buyer_id%TYPE,
        p_qty        IN sale.quantity_sold%TYPE,
        p_price      IN sale.unit_price%TYPE
    );

    PROCEDURE process_payment (
        p_sale_id IN payment.sale_id%TYPE,
        p_amount  IN payment.amount%TYPE,
        p_method  IN payment.payment_method%TYPE
    );

    FUNCTION get_farmer_revenue (
        p_farmer_id IN farmer.farmer_id%TYPE
    ) RETURN NUMBER;

    PROCEDURE list_unpaid_sales;

END farm_pkgCREATE OR REPLACE PACKAGE BODY farm_pkg AS

------- Register a new harvest---------
    PROCEDURE register_harvest (
        p_farm_id  IN harvest.farm_id%TYPE,
        p_crop_id  IN harvest.crop_id%TYPE,
        p_date     IN harvest.harvest_date%TYPE,
        p_qty      IN harvest.quantity%TYPE,
        p_grade    IN harvest.quality_grade%TYPE
    ) IS
    BEGIN
        IF p_qty <= 0 THEN
            RAISE_APPLICATION_ERROR(-20003, 'Harvest quantity must be positive.');
        END IF;

        INSERT INTO harvest (harvest_id, farm_id, crop_id, harvest_date, quantity, quality_grade)
        VALUES (seq_harvest_id.NEXTVAL, p_farm_id, p_crop_id, p_date, p_qty, p_grade);

        COMMIT;
        DBMS_OUTPUT.PUT_LINE('Harvest recorded successfully.');
    EXCEPTION
        WHEN OTHERS THEN
            ROLLBACK;
            DBMS_OUTPUT.PUT_LINE('Error recording harvest: ' || SQLERRM);
    END register_harvest;

------- Record a sale, checking remaining harvest quantity---------
    PROCEDURE record_sale (
        p_harvest_id IN sale.harvest_id%TYPE,
        p_buyer_id   IN sale.buyer_id%TYPE,
        p_qty        IN sale.quantity_sold%TYPE,
        p_price      IN sale.unit_price%TYPE
    ) IS
        v_harvested   harvest.quantity%TYPE;
        v_already_sold NUMBER;
        v_remaining   NUMBER;
    BEGIN
        SELECT quantity INTO v_harvested
        FROM harvest WHERE harvest_id = p_harvest_id;

        SELECT NVL(SUM(quantity_sold), 0) INTO v_already_sold
        FROM sale WHERE harvest_id = p_harvest_id;

        v_remaining := v_harvested - v_already_sold;

        IF p_qty > v_remaining THEN
            RAISE e_insufficient_qty;
        END IF;

        INSERT INTO sale (sale_id, harvest_id, buyer_id, sale_date, quantity_sold, unit_price)
        VALUES (seq_sale_id.NEXTVAL, p_harvest_id, p_buyer_id, SYSDATE, p_qty, p_price);

        COMMIT;
        DBMS_OUTPUT.PUT_LINE('Sale recorded successfully.');
    EXCEPTION
        WHEN e_insufficient_qty THEN
            ROLLBACK;
            DBMS_OUTPUT.PUT_LINE('Error: Not enough remaining quantity. Available: ' || v_remaining);
        WHEN NO_DATA_FOUND THEN
            ROLLBACK;
            DBMS_OUTPUT.PUT_LINE('Error: Harvest ID not found.');
        WHEN OTHERS THEN
            ROLLBACK;
            DBMS_OUTPUT.PUT_LINE('Unexpected error: ' || SQLERRM);
    END record_sale;

    -- Process a payment for a sale
    PROCEDURE process_payment (
        p_sale_id IN payment.sale_id%TYPE,
        p_amount  IN payment.amount%TYPE,
        p_method  IN payment.payment_method%TYPE
    ) IS
        v_expected NUMBER;
    BEGIN
        v_expected := calc_sale_total(p_sale_id);

        IF p_amount != v_expected THEN
            DBMS_OUTPUT.PUT_LINE('Warning: amount does not match expected total (' || v_expected || ').');
        END IF;

        INSERT INTO payment (payment_id, sale_id, payment_date, amount, payment_method, status)
        VALUES (seq_payment_id.NEXTVAL, p_sale_id, SYSDATE, p_amount, p_method, 'PAID');

        COMMIT;
        DBMS_OUTPUT.PUT_LINE('Payment processed successfully.');
    EXCEPTION
        WHEN DUP_VAL_ON_INDEX THEN
            ROLLBACK;
            DBMS_OUTPUT.PUT_LINE('Error: A payment already exists for this sale.');
        WHEN OTHERS THEN
            ROLLBACK;
            DBMS_OUTPUT.PUT_LINE('Error processing payment: ' || SQLERRM);
    END process_payment;

    -- Function: total revenue for a farmer across all sales
    FUNCTION get_farmer_revenue (
        p_farmer_id IN farmer.farmer_id%TYPE
    ) RETURN NUMBER IS
        v_revenue NUMBER := 0;
    BEGIN
        SELECT NVL(SUM(s.quantity_sold * s.unit_price), 0)
        INTO   v_revenue
        FROM   sale s
        JOIN   harvest h ON s.harvest_id = h.harvest_id
        JOIN   farm f    ON h.farm_id = f.farm_id
        WHERE  f.farmer_id = p_farmer_id;

        RETURN v_revenue;
    END get_farmer_revenue;

    -- Explicit cursor: list all sales with pending payments
    PROCEDURE list_unpaid_sales IS
        CURSOR c_unpaid IS
            SELECT s.sale_id, b.buyer_name, s.quantity_sold, s.unit_price,
                   (s.quantity_sold * s.unit_price) AS total_due
            FROM   sale s
            JOIN   buyer b ON s.buyer_id = b.buyer_id
            WHERE  s.sale_id NOT IN (SELECT sale_id FROM payment);
        v_rec c_unpaid%ROWTYPE;
    BEGIN
        OPEN c_unpaid;
        LOOP
            FETCH c_unpaid INTO v_rec;
            EXIT WHEN c_unpaid%NOTFOUND;
            DBMS_OUTPUT.PUT_LINE('Sale ' || v_rec.sale_id || ' | Buyer: ' || v_rec.buyer_name ||
                                  ' | Due: ' || v_rec.total_due);
        END LOOP;
        CLOSE c_unpaid;
    END list_unpaid_sales;

END farm_pkg;
