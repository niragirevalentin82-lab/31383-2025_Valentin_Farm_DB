-------transaction control demo--------
SET SERVEROUTPUT ON;

BEGIN
    farm_pkg.register_harvest(1, 1, DATE '2026-05-01', 400, 'A');
    farm_pkg.record_sale(1, 2, 150, 400);      -- succeeds
    farm_pkg.record_sale(1, 1, 1000, 400);     -- fails: exceeds remaining qty, triggers ROLLBACK
    farm_pkg.process_payment(1, 70000, 'CASH');
    farm_pkg.list_unpaid_sales;
END;
