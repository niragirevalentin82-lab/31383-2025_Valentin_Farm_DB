-------calculate sale total--------
CREATE OR REPLACE FUNCTION calc_sale_total (
    p_sale_id IN sale.sale_id%TYPE
) RETURN NUMBER
IS
    v_total NUMBER(12,2);
BEGIN
    SELECT quantity_sold * unit_price
    INTO   v_total
    FROM   sale
    WHERE  sale_id = p_sale_id;

    RETURN v_total;
EXCEPTION
    WHEN NO_DATA_FOUND THEN
        RAISE_APPLICATION_ERROR(-20001, 'Sale ID ' || p_sale_id || ' not found.');
END calc_sale_total;
