--------register a new farmer (parameterized)------------
CREATE OR REPLACE PROCEDURE register_farmer (
    p_name        IN farmer.full_name%TYPE,
    p_phone       IN farmer.phone%TYPE,
    p_national_id IN farmer.national_id%TYPE,
    p_address     IN farmer.address%TYPE
)
IS
    v_dup_count NUMBER;
BEGIN
    SELECT COUNT(*) INTO v_dup_count
    FROM farmer
    WHERE national_id = p_national_id;

    IF v_dup_count > 0 THEN
        RAISE_APPLICATION_ERROR(-20002, 'A farmer with this national ID already exists.');
    END IF;

    INSERT INTO farmer (farmer_id, full_name, phone, national_id, address, registered_on)
    VALUES (seq_farmer_id.NEXTVAL, p_name, p_phone, p_national_id, p_address, SYSDATE);

    COMMIT;
    DBMS_OUTPUT.PUT_LINE('Farmer registered successfully: ' || p_name);
EXCEPTION
    WHEN OTHERS THEN
        ROLLBACK;
        DBMS_OUTPUT.PUT_LINE('Error registering farmer: ' || SQLERRM);
END register_farmer;
